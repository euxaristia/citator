# Discord Bot Configuration
CITATOR_DISCORD_TOKEN=your_bot_token_here
CITATOR_CLIENT_ID=your_client_id_here
CITATOR_GUILD_ID=your_guild_id_here

# Daily Verse Schedule (cron format: minute hour day month weekday)
# Default: 8:00 AM daily
DAILY_VERSE_SCHEDULE="0 8 * * *"

# Default Bible Version
DEFAULT_VERSION=ESV

# Timezone for daily verses (IANA timezone format)
TIMEZONE=America/New_York
